{
  "name": "@attractor/cli",
  "version": "0.1.0",
  "description": "CLI frontend for Attractor pipeline runner",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "attractor": "dist/bin.js"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests --exclude 'tests/golden/**'",
    "test:golden": "pnpm build && vitest run tests/golden/golden-regression.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@attractor/backend-pi-dev": "0.1.0",
    "@attractor/core": "0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
