{
  "name": "@jhugman/attractor-pi",
  "version": "0.1.0",
  "description": "Compatibility package for legacy Attractor Pi packaging",
  "type": "module",
  "license": "Apache-2.0",
  "engines": { "node": ">=20" },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.52.9",
    "@mariozechner/pi-ai": "^0.52.9",
    "@mariozechner/pi-agent-core": "^0.52.9"
  },
  "devDependencies": {
    "@attractor/cli": "workspace:*",
    "@attractor/backend-pi-dev": "workspace:*",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm --filter @attractor/core --filter @attractor/backend-pi-dev --filter @attractor/cli build",
    "test:smoke": "pnpm build && vitest run --passWithNoTests tests/smoke.test.ts"
  }
}
